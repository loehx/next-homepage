## JSX Complexity

**Maximum ternary nesting: 1 level.** Extract complex conditional logic to functions or components.

```typescript
// ❌ Wrong: Nested ternaries
function Status({ user }: Props) {
  return (
    <div>
      {user.isActive ? (
        user.isPremium ? (
          <PremiumBadge />
        ) : (
          <FreeBadge />
        )
      ) : (
        <InactiveBadge />
      )}
    </div>
  );
}

// ✅ Correct: Extract to function
function Status({ user }: Props) {
  const getBadge = () => {
    if (!user.isActive) return <InactiveBadge />;
    if (user.isPremium) return <PremiumBadge />;
    return <FreeBadge />;
  };
  
  return <div>{getBadge()}</div>;
}

// ✅ Or extract to component
function Status({ user }: Props) {
  return <div><UserBadge user={user} /></div>;
}
```

**Complex inline logic must be extracted:**

```typescript
// ❌ Wrong: Complex calculations in JSX
function ProductCard({ product }: Props) {
  return (
    <div>
      <h2>{product.name}</h2>
      <p>
        ${(product.price * (1 - product.discount) * (1 + product.tax)).toFixed(2)}
      </p>
    </div>
  );
}

// ✅ Correct: Extract calculation
function ProductCard({ product }: Props) {
  const finalPrice = calculateFinalPrice(product);
  
  return (
    <div>
      <h2>{product.name}</h2>
      <p>${finalPrice}</p>
    </div>
  );
}

function calculateFinalPrice(product: Product): string {
  const withDiscount = product.price * (1 - product.discount);
  const withTax = withDiscount * (1 + product.tax);
  return withTax.toFixed(2);
}
```

**Single-level ternaries are acceptable:**

```typescript
// ✅ Good: Simple, readable ternary
function Button({ isLoading, children }: Props) {
  return (
    <button>
      {isLoading ? <Spinner /> : children}
    </button>
  );
}
```

